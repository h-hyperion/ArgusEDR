<Window x:Class="Argus.GUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Argus.GUI.ViewModels"
        xmlns:views="clr-namespace:Argus.GUI.Views"
        xmlns:converters="clr-namespace:Argus.GUI.Converters"
        Title="Argus EDR" Height="780" Width="1180" MinWidth="980" MinHeight="640"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgPrimary}"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>

        <!-- Map ViewModel types to View controls -->
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ScannerViewModel}">
            <views:ScannerView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:DefenderViewModel}">
            <views:DefenderView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PrivacyGuardViewModel}">
            <views:PrivacyGuardView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:QuarantineViewModel}">
            <views:QuarantineView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView/>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ============================================================ -->
        <!-- Cross-page emergency strip                                    -->
        <!-- Only visible when IsSafeMode == true. The dashboard banner    -->
        <!-- is the rich, dual-state version; this strip ensures the user -->
        <!-- sees the alert no matter which module they're on.             -->
        <!-- ============================================================ -->
        <Border Grid.Row="0"
                Background="{StaticResource BgCrimsonBanner}"
                BorderBrush="{StaticResource AccentGold}"
                BorderThickness="0 0 0 2"
                Padding="24 10"
                Visibility="{Binding IsSafeMode, Converter={StaticResource BoolToVisibility}}">
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Content="Repair Argus"
                        Style="{StaticResource ReviewButton}"
                        Margin="16 0 0 0"
                        Command="{Binding RepairArgusCommand}"/>
                <TextBlock VerticalAlignment="Center"
                           FontFamily="{StaticResource FontCinzel}"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource AccentGoldLight}"
                           Text="{Binding SafeModeReason, StringFormat='SAFE MODE ACTIVE — {0}'}"/>
            </DockPanel>
        </Border>

        <!-- Main Content: Sidebar + Topbar + Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="232"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ============================================================ -->
            <!-- Sidebar — Imperial Crest brand stage + nav                    -->
            <!-- ============================================================ -->
            <Grid Grid.Column="0">
              <!-- Sidebar background + border -->
              <Border Background="{StaticResource BgSidebarGradient}"
                      BorderBrush="{StaticResource BorderDefault}"
                      BorderThickness="0 0 1 0"/>
              <!-- Gold edge glow (matching mockup's ::after gradient) -->
              <Rectangle Width="1" HorizontalAlignment="Right"
                         Fill="{StaticResource GoldRuleVertical}"
                         IsHitTestVisible="False" Panel.ZIndex="1"/>
              <Border>
                <DockPanel>
                    <!-- ================================================== -->
                    <!-- Brand header — Imperial Crest                       -->
                    <!--                                                      -->
                    <!-- Compass crosshair motif behind ARGUS wordmark,       -->
                    <!-- horizontal gold rules flanking a crimson-diamond     -->
                    <!-- "EDR · V2.1.1" plate below it.                       -->
                    <!-- ================================================== -->
                    <Border DockPanel.Dock="Top"
                            Background="{StaticResource BgBrandHeader}"
                            BorderBrush="{StaticResource BorderDefault}"
                            BorderThickness="0 0 0 1"
                            Padding="20 34 20 28">
                        <Grid>
                            <!-- ================================ -->
                            <!-- Compass crosshair motif (behind)  -->
                            <!-- ================================ -->
                            <Grid HorizontalAlignment="Center"
                                  VerticalAlignment="Top"
                                  Width="140" Height="140"
                                  Margin="0 -8 0 0"
                                  IsHitTestVisible="False">
                                <!-- Outer ring -->
                                <Ellipse Width="140" Height="140"
                                         Stroke="{StaticResource AccentGold}"
                                         StrokeThickness="0.8"
                                         Opacity="0.22"/>
                                <!-- Inner ring -->
                                <Ellipse Width="92" Height="92"
                                         Stroke="{StaticResource AccentGold}"
                                         StrokeThickness="0.6"
                                         Opacity="0.18"/>
                                <!-- Horizontal crosshair -->
                                <Rectangle Height="0.8" Width="156"
                                           Fill="{StaticResource AccentGold}"
                                           Opacity="0.18"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                                <!-- Vertical crosshair -->
                                <Rectangle Width="0.8" Height="156"
                                           Fill="{StaticResource AccentGold}"
                                           Opacity="0.18"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                                <!-- Diagonal tick marks (NE/NW/SE/SW) -->
                                <Rectangle Width="0.5" Height="16"
                                           Fill="{StaticResource AccentGold}"
                                           Opacity="0.22"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Top"
                                           Margin="0 6 0 0"
                                           RenderTransformOrigin="0.5,0.5">
                                    <Rectangle.RenderTransform>
                                        <RotateTransform Angle="45"/>
                                    </Rectangle.RenderTransform>
                                </Rectangle>
                                <Rectangle Width="0.5" Height="16"
                                           Fill="{StaticResource AccentGold}"
                                           Opacity="0.22"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Top"
                                           Margin="0 6 0 0"
                                           RenderTransformOrigin="0.5,0.5">
                                    <Rectangle.RenderTransform>
                                        <RotateTransform Angle="-45"/>
                                    </Rectangle.RenderTransform>
                                </Rectangle>
                            </Grid>

                            <!-- ================================ -->
                            <!-- Wordmark + subtitle (foreground)  -->
                            <!-- ================================ -->
                            <StackPanel>
                                <TextBlock Text="ARGUS"
                                           Style="{StaticResource WordmarkText}"
                                           FontSize="32"
                                           HorizontalAlignment="Center">
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="#FFE8C578"
                                                          BlurRadius="10"
                                                          ShadowDepth="0"
                                                          Opacity="0.55"/>
                                    </TextBlock.Effect>
                                </TextBlock>

                                <!-- Subtitle plate: rule | diamond | "EDR · V2.1.1" | diamond | rule -->
                                <Grid Margin="0 10 0 0" HorizontalAlignment="Center">
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center">
                                        <!-- Left gold rule -->
                                        <Rectangle Width="34" Height="1"
                                                   Fill="{StaticResource AccentGold}"
                                                   Opacity="0.75"
                                                   VerticalAlignment="Center"
                                                   Margin="0 0 8 0"/>
                                        <!-- Left crimson diamond -->
                                        <Rectangle Width="6" Height="6"
                                                   Fill="{StaticResource AccentRedCritical}"
                                                   VerticalAlignment="Center"
                                                   RenderTransformOrigin="0.5,0.5">
                                            <Rectangle.RenderTransform>
                                                <RotateTransform Angle="45"/>
                                            </Rectangle.RenderTransform>
                                            <Rectangle.Effect>
                                                <DropShadowEffect Color="#FFE83D55"
                                                                  BlurRadius="6"
                                                                  ShadowDepth="0"
                                                                  Opacity="0.8"/>
                                            </Rectangle.Effect>
                                        </Rectangle>
                                        <!-- Subtitle text -->
                                        <TextBlock Margin="10 0 10 0"
                                                   Style="{StaticResource BrandSubText}"
                                                   Text="EDR · V2.1.1"/>
                                        <!-- Right crimson diamond -->
                                        <Rectangle Width="6" Height="6"
                                                   Fill="{StaticResource AccentRedCritical}"
                                                   VerticalAlignment="Center"
                                                   RenderTransformOrigin="0.5,0.5">
                                            <Rectangle.RenderTransform>
                                                <RotateTransform Angle="45"/>
                                            </Rectangle.RenderTransform>
                                            <Rectangle.Effect>
                                                <DropShadowEffect Color="#FFE83D55"
                                                                  BlurRadius="6"
                                                                  ShadowDepth="0"
                                                                  Opacity="0.8"/>
                                            </Rectangle.Effect>
                                        </Rectangle>
                                        <!-- Right gold rule -->
                                        <Rectangle Width="34" Height="1"
                                                   Fill="{StaticResource AccentGold}"
                                                   Opacity="0.75"
                                                   VerticalAlignment="Center"
                                                   Margin="8 0 0 0"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Sidebar footer (status) -->
                    <Border DockPanel.Dock="Bottom"
                            BorderBrush="{StaticResource BorderDefault}"
                            BorderThickness="0 1 0 0"
                            Padding="20 16">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock HorizontalAlignment="Center"
                                       FontFamily="{StaticResource FontBarlowCondensed}"
                                       FontSize="11"
                                       Foreground="{StaticResource TextMuted}">
                                <Run Foreground="{StaticResource StatusGreen}" Text="●"/>
                                <Run Text=" PROTECTED · ENGINE 2.1.1"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- Nav Items (uppercase to match mockup's text-transform) -->
                    <StackPanel Margin="0 22 0 0">
                        <Button Content="DASHBOARD"     Style="{StaticResource NavButton}"
                                Command="{Binding ShowDashboardCommand}"/>
                        <Button Content="SCANNER"       Style="{StaticResource NavButton}"
                                Command="{Binding ShowScannerCommand}"/>
                        <Button Content="DEFENDER"      Style="{StaticResource NavButton}"
                                Command="{Binding ShowDefenderCommand}"/>
                        <Button Content="PRIVACY GUARD" Style="{StaticResource NavButton}"
                                Command="{Binding ShowPrivacyGuardCommand}"/>
                        <Button Content="QUARANTINE"    Style="{StaticResource NavButton}"
                                Command="{Binding ShowQuarantineCommand}"/>
                        <Button Content="SETTINGS"      Style="{StaticResource NavButton}"
                                Command="{Binding ShowSettingsCommand}"/>
                    </StackPanel>
                </DockPanel>
              </Border>
            </Grid>

            <!-- ============================================================ -->
            <!-- Right side: topbar + content                                  -->
            <!-- ============================================================ -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Topbar -->
                <Grid Grid.Row="0">
                  <Border BorderBrush="{StaticResource BorderDefault}"
                          BorderThickness="0 0 0 1"
                          Padding="36 28 36 22">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0" VerticalAlignment="Center">
                            <!-- Decorative gear/cog behind the title -->
                            <Path Data="M 20,2 L 22,8 L 28,6 L 26,12 L 32,14 L 26,16 L 28,22 L 22,20 L 20,26 L 18,20 L 12,22 L 14,16 L 8,14 L 14,12 L 12,6 L 18,8 Z M 20,10 A 4,4 0 1 0 20,18 A 4,4 0 1 0 20,10 Z"
                                  Width="56" Height="56"
                                  Stretch="Uniform"
                                  Fill="#08D4AF4B"
                                  Stroke="#15D4AF4B"
                                  StrokeThickness="0.5"
                                  HorizontalAlignment="Left"
                                  Margin="-8 0 0 0"
                                  IsHitTestVisible="False"/>
                            <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                <TextBlock Text="—  " VerticalAlignment="Center"
                                           FontFamily="{StaticResource FontCinzel}"
                                           FontSize="28" FontWeight="Light"
                                           Foreground="{StaticResource AccentGold}"/>
                                <TextBlock Text="{Binding CurrentPageTitle}"
                                           Style="{StaticResource CinzelPageTitle}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Style="{StaticResource StatusPill}" Margin="0 0 14 0">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="6" Height="6" VerticalAlignment="Center"
                                             Fill="{StaticResource StatusGreen}">
                                        <Ellipse.Effect>
                                            <DropShadowEffect Color="#FF6FD185" BlurRadius="8" ShadowDepth="0" Opacity="0.9"/>
                                        </Ellipse.Effect>
                                    </Ellipse>
                                    <TextBlock Margin="8 0 0 0"
                                               FontFamily="{StaticResource FontBarlowCondensed}"
                                               FontSize="11"
                                               FontWeight="Medium"
                                               Foreground="{StaticResource StatusGreen}"
                                               Text="PROTECTED"/>
                                </StackPanel>
                            </Border>
                            <Button Content="Quick Scan"
                                    Style="{StaticResource PrimaryButton}"
                                    Command="{Binding ShowScannerCommand}"/>
                        </StackPanel>
                    </Grid>
                  </Border>
                  <!-- Gold gradient underline (mockup's topbar::after) -->
                  <Rectangle Height="1" VerticalAlignment="Bottom"
                             HorizontalAlignment="Stretch" Margin="36 0"
                             IsHitTestVisible="False" Panel.ZIndex="1">
                      <Rectangle.Fill>
                          <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                              <GradientStop Color="#FFD4AF4B" Offset="0"/>
                              <GradientStop Color="#00D4AF4B" Offset="0.5"/>
                          </LinearGradientBrush>
                      </Rectangle.Fill>
                  </Rectangle>
                </Grid>

                <!-- Content area — layered radial glow matching Imperial Crest mockup -->
                <Grid Grid.Row="1">
                    <!-- Warm crimson radial wash (top-center, like the HTML body background) -->
                    <Border IsHitTestVisible="False">
                        <Border.Background>
                            <RadialGradientBrush Center="0.5,-0.1" GradientOrigin="0.5,-0.1"
                                                  RadiusX="0.7" RadiusY="0.5">
                                <GradientStop Color="#30C2243A" Offset="0"/>
                                <GradientStop Color="#00000000" Offset="1"/>
                            </RadialGradientBrush>
                        </Border.Background>
                    </Border>
                    <!-- Subtle gold warmth (bottom-right corner) -->
                    <Border IsHitTestVisible="False">
                        <Border.Background>
                            <RadialGradientBrush Center="1.0,1.0" GradientOrigin="1.0,1.0"
                                                  RadiusX="0.6" RadiusY="0.5">
                                <GradientStop Color="#10D4AF4B" Offset="0"/>
                                <GradientStop Color="#00000000" Offset="1"/>
                            </RadialGradientBrush>
                        </Border.Background>
                    </Border>
                    <!-- Actual content -->
                    <Border Padding="36 26">
                        <ContentControl Content="{Binding CurrentView}"/>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="2"
                Background="{StaticResource BgSurface}"
                BorderBrush="{StaticResource BorderDefault}"
                BorderThickness="0 1 0 0"
                Padding="20 8">
            <TextBlock Text="{Binding PipeBridgeStatus}"
                       FontFamily="{StaticResource FontBarlowCondensed}"
                       FontSize="11"
                       Foreground="{StaticResource TextMuted}"/>
        </Border>
    </Grid>
</Window>
