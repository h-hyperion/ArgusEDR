<Window x:Class="Argus.GUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Argus.GUI.ViewModels"
        xmlns:views="clr-namespace:Argus.GUI.Views"
        xmlns:converters="clr-namespace:Argus.GUI.Converters"
        Title="Argus EDR" Height="780" Width="1180" MinWidth="980" MinHeight="640"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgPrimary}"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>

        <!-- Map ViewModel types to View controls -->
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ScannerViewModel}">
            <views:ScannerView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:DefenderViewModel}">
            <views:DefenderView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PrivacyGuardViewModel}">
            <views:PrivacyGuardView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:QuarantineViewModel}">
            <views:QuarantineView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView/>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ============================================================ -->
        <!-- Cross-page emergency strip                                    -->
        <!-- Only visible when IsSafeMode == true. The dashboard banner    -->
        <!-- is the rich, dual-state version; this strip ensures the user -->
        <!-- sees the alert no matter which module they're on.             -->
        <!-- ============================================================ -->
        <Border Grid.Row="0"
                Background="{StaticResource BgCrimsonBanner}"
                BorderBrush="{StaticResource AccentGold}"
                BorderThickness="0 0 0 2"
                Padding="24 10"
                Visibility="{Binding IsSafeMode, Converter={StaticResource BoolToVisibility}}">
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Content="Repair Argus"
                        Style="{StaticResource ReviewButton}"
                        Margin="16 0 0 0"
                        Command="{Binding RepairArgusCommand}"/>
                <TextBlock VerticalAlignment="Center"
                           FontFamily="{StaticResource FontCinzel}"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource AccentGoldLight}"
                           Text="{Binding SafeModeReason, StringFormat='SAFE MODE ACTIVE — {0}'}"/>
            </DockPanel>
        </Border>

        <!-- Main Content: Sidebar + Topbar + Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="232"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ============================================================ -->
            <!-- Sidebar — Imperial Crest brand stage + nav                    -->
            <!-- ============================================================ -->
            <Border Grid.Column="0"
                    Background="{StaticResource BgSidebarGradient}"
                    BorderBrush="{StaticResource BorderDefault}"
                    BorderThickness="0 0 1 0">
                <DockPanel>
                    <!-- Brand header -->
                    <Border DockPanel.Dock="Top"
                            Background="{StaticResource BgBrandHeader}"
                            BorderBrush="{StaticResource BorderDefault}"
                            BorderThickness="0 0 0 1"
                            Padding="20 32 20 26">
                        <StackPanel>
                            <Rectangle Height="2" Margin="14 0 14 14" Fill="{StaticResource GoldRule}"/>
                            <TextBlock Text="ARGUS"
                                       Style="{StaticResource WordmarkText}"
                                       FontSize="30"/>
                            <TextBlock Margin="0 4 0 0"
                                       Style="{StaticResource BrandSubText}"
                                       Text="❖  EDR · v2.1  ❖"/>
                            <Rectangle Height="2" Margin="14 14 14 0" Fill="{StaticResource GoldRule}"/>
                        </StackPanel>
                    </Border>

                    <!-- Sidebar footer (status) -->
                    <Border DockPanel.Dock="Bottom"
                            BorderBrush="{StaticResource BorderDefault}"
                            BorderThickness="0 1 0 0"
                            Padding="20 16">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock HorizontalAlignment="Center"
                                       FontFamily="{StaticResource FontBarlowCondensed}"
                                       FontSize="11"
                                       Foreground="{StaticResource TextMuted}">
                                <Run Foreground="{StaticResource StatusGreen}" Text="●"/>
                                <Run Text=" PROTECTED · ENGINE 2.1.0"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- Nav Items -->
                    <StackPanel Margin="0 22 0 0">
                        <Button Content="Dashboard"     Style="{StaticResource NavButton}"
                                Command="{Binding ShowDashboardCommand}"/>
                        <Button Content="Scanner"       Style="{StaticResource NavButton}"
                                Command="{Binding ShowScannerCommand}"/>
                        <Button Content="Defender"      Style="{StaticResource NavButton}"
                                Command="{Binding ShowDefenderCommand}"/>
                        <Button Content="Privacy Guard" Style="{StaticResource NavButton}"
                                Command="{Binding ShowPrivacyGuardCommand}"/>
                        <Button Content="Quarantine"    Style="{StaticResource NavButton}"
                                Command="{Binding ShowQuarantineCommand}"/>
                        <Button Content="Settings"      Style="{StaticResource NavButton}"
                                Command="{Binding ShowSettingsCommand}"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- ============================================================ -->
            <!-- Right side: topbar + content                                  -->
            <!-- ============================================================ -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Topbar -->
                <Border Grid.Row="0"
                        BorderBrush="{StaticResource BorderDefault}"
                        BorderThickness="0 0 0 1"
                        Padding="36 28 36 22">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Orientation="Horizontal">
                            <TextBlock Text="—  " VerticalAlignment="Center"
                                       FontFamily="{StaticResource FontCinzel}"
                                       FontSize="28" FontWeight="Light"
                                       Foreground="{StaticResource AccentGold}"/>
                            <TextBlock Text="{Binding CurrentPageTitle}"
                                       Style="{StaticResource CinzelPageTitle}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Style="{StaticResource StatusPill}" Margin="0 0 14 0">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="6" Height="6" VerticalAlignment="Center"
                                             Fill="{StaticResource StatusGreen}">
                                        <Ellipse.Effect>
                                            <DropShadowEffect Color="#FF6FD185" BlurRadius="8" ShadowDepth="0" Opacity="0.9"/>
                                        </Ellipse.Effect>
                                    </Ellipse>
                                    <TextBlock Margin="8 0 0 0"
                                               FontFamily="{StaticResource FontBarlowCondensed}"
                                               FontSize="11"
                                               FontWeight="Medium"
                                               Foreground="{StaticResource StatusGreen}"
                                               Text="PROTECTED"/>
                                </StackPanel>
                            </Border>
                            <Button Content="Quick Scan"
                                    Style="{StaticResource PrimaryButton}"
                                    Command="{Binding ShowScannerCommand}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Content area -->
                <Border Grid.Row="1" Padding="36 26">
                    <ContentControl Content="{Binding CurrentView}"/>
                </Border>
            </Grid>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="2"
                Background="{StaticResource BgSurface}"
                BorderBrush="{StaticResource BorderDefault}"
                BorderThickness="0 1 0 0"
                Padding="20 8">
            <TextBlock Text="{Binding PipeBridgeStatus}"
                       FontFamily="{StaticResource FontBarlowCondensed}"
                       FontSize="11"
                       Foreground="{StaticResource TextMuted}"/>
        </Border>
    </Grid>
</Window>
