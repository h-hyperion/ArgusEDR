<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="ArgusTheme.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!-- ================================================================ -->
    <!--  ARGUS EDR — IMPERIAL CREST CONTROLS                               -->
    <!--  Buttons, nav, toggles, text styles, scrollbars, combobox.         -->
    <!-- ================================================================ -->

    <!-- ================================================================ -->
    <!--  Text styles — Cinzel headings / Barlow body                       -->
    <!-- ================================================================ -->

    <Style x:Key="WordmarkText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontCinzel}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="30"/>
        <Setter Property="Foreground" Value="{StaticResource AccentGoldLight}"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#FFC2243A" BlurRadius="12" ShadowDepth="0" Opacity="0.5"/>
            </Setter.Value>
        </Setter>
        <Style.Resources>
            <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}"/>
        </Style.Resources>
    </Style>

    <Style x:Key="BrandSubText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontBarlowCondensed}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Foreground" Value="{StaticResource AccentGold}"/>
        <Setter Property="Opacity" Value="0.85"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="CinzelPageTitle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontCinzel}"/>
        <Setter Property="FontSize" Value="28"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
    </Style>

    <Style x:Key="CinzelSectionTitle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontCinzel}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Foreground" Value="{StaticResource AccentGold}"/>
        <Setter Property="Margin" Value="0 16 0 12"/>
    </Style>

    <Style x:Key="BodyText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontBarlow}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
    </Style>

    <Style x:Key="LabelText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontBarlowCondensed}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Foreground" Value="{StaticResource AccentGold}"/>
    </Style>

    <!-- Apply Barlow as the default app-wide font. Any TextBlock without an
         explicit FontFamily inherits Barlow so views we don't touch still
         pick up the Imperial Crest typography. -->
    <Style TargetType="{x:Type TextBlock}">
        <Setter Property="FontFamily" Value="{StaticResource FontBarlow}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
    </Style>

    <!-- ================================================================ -->
    <!--  Primary Button — stamped gold brass, chevron-clipped               -->
    <!-- ================================================================ -->
    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource BgGoldBrass}"/>
        <Setter Property="Foreground" Value="{StaticResource TextInverse}"/>
        <Setter Property="BorderBrush" Value="{StaticResource AccentGoldDim}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="24 12"/>
        <Setter Property="FontFamily" Value="{StaticResource FontBarlowCondensed}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          TextBlock.FontFamily="{StaticResource FontBarlowCondensed}"
                                          TextBlock.FontWeight="SemiBold"
                                          TextBlock.FontSize="13"
                                          TextBlock.Foreground="{StaticResource TextInverse}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgGoldBrassHover}"/>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentGold}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentGoldPressed}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ================================================================ -->
    <!--  Secondary Button — ghost gold                                     -->
    <!-- ================================================================ -->
    <Style x:Key="SecondaryButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource AccentGold}"/>
        <Setter Property="BorderBrush" Value="{StaticResource AccentGold}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="18 10"/>
        <Setter Property="FontFamily" Value="{StaticResource FontBarlowCondensed}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          TextBlock.FontFamily="{StaticResource FontBarlowCondensed}"
                                          TextBlock.FontSize="12"
                                          TextBlock.FontWeight="SemiBold"
                                          TextBlock.Foreground="{StaticResource AccentGold}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#14D4AF4B"/>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentGoldLight}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#26D4AF4B"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.35"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ================================================================ -->
    <!--  Small Button — compact ghost                                      -->
    <!-- ================================================================ -->
    <Style x:Key="SmallButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
        <Setter Property="Padding" Value="12 6"/>
        <Setter Property="FontSize" Value="11"/>
    </Style>

    <!-- ================================================================ -->
    <!--  Danger Button — crimson stamped                                    -->
    <!-- ================================================================ -->
    <Style x:Key="DangerButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource BgOxblood}"/>
        <Setter Property="Foreground" Value="{StaticResource AccentRedCritical}"/>
        <Setter Property="BorderBrush" Value="{StaticResource AccentRed}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="18 10"/>
        <Setter Property="FontFamily" Value="{StaticResource FontBarlowCondensed}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentRedCritical}"/>
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgOxbloodDeep}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ================================================================ -->
    <!--  Review Button — Cinzel oxblood frame with gold inscription         -->
    <!-- ================================================================ -->
    <Style x:Key="ReviewButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource BgOxblood}"/>
        <Setter Property="Foreground" Value="{StaticResource AccentGoldLight}"/>
        <Setter Property="BorderBrush" Value="{StaticResource AccentGold}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="22 12"/>
        <Setter Property="FontFamily" Value="{StaticResource FontCinzel}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          TextBlock.FontFamily="{StaticResource FontCinzel}"
                                          TextBlock.FontSize="13"
                                          TextBlock.FontWeight="SemiBold"
                                          TextBlock.Foreground="{StaticResource AccentGoldLight}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentGoldLight}"/>
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgOxbloodDeep}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ================================================================ -->
    <!--  Nav Button — sidebar navigation with gold left-border on active   -->
    <!-- ================================================================ -->
    <Style x:Key="NavButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="22 14"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="FontFamily" Value="{StaticResource FontBarlowCondensed}"/>
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="Transparent"
                            BorderThickness="2 0 0 0"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter VerticalAlignment="Center"
                                          HorizontalAlignment="Left"
                                          TextBlock.FontFamily="{StaticResource FontBarlowCondensed}"
                                          TextBlock.FontSize="15"
                                          TextBlock.FontWeight="Medium"
                                          TextBlock.TextAlignment="Left"
                                          TextBlock.Foreground="{TemplateBinding Foreground}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgNavHover}"/>
                            <Setter Property="Foreground" Value="{StaticResource AccentGoldLight}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgNavActive}"/>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentGold}"/>
                            <Setter Property="Foreground" Value="{StaticResource AccentGoldLight}"/>
                            <Setter Property="Opacity" Value="1"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ================================================================ -->
    <!--  Toggle Switch — used for Privacy Guard toggles                    -->
    <!--  Templates a CheckBox into a pill track + gold thumb.              -->
    <!-- ================================================================ -->
    <Style x:Key="ToggleSwitch" TargetType="CheckBox">
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Grid Width="44" Height="22">
                        <Border x:Name="Track"
                                Background="#33000000"
                                BorderBrush="{StaticResource BorderDefault}"
                                BorderThickness="1"
                                CornerRadius="11"/>
                        <Ellipse x:Name="Thumb"
                                 Width="16" Height="16"
                                 HorizontalAlignment="Left"
                                 Margin="3 0 0 0"
                                 Fill="{StaticResource TextSecondary}"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Track" Property="Background" Value="{StaticResource BgGoldBrass}"/>
                            <Setter TargetName="Track" Property="BorderBrush" Value="{StaticResource AccentGold}"/>
                            <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                            <Setter TargetName="Thumb" Property="Margin" Value="0 0 3 0"/>
                            <Setter TargetName="Thumb" Property="Fill" Value="{StaticResource TextPrimary}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Track" Property="BorderBrush" Value="{StaticResource AccentGoldLight}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ================================================================ -->
    <!--  Pill badge (status indicator)                                     -->
    <!-- ================================================================ -->
    <Style x:Key="StatusPill" TargetType="Border">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="{StaticResource AccentGold}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="14 7"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- ================================================================ -->
    <!--  Scrollbar — slim gold-tinted                                      -->
    <!-- ================================================================ -->
    <SolidColorBrush x:Key="ScrollbarTrack"       Color="#FF0A0303"/>
    <SolidColorBrush x:Key="ScrollbarThumb"       Color="#FF3C2D17"/>
    <SolidColorBrush x:Key="ScrollbarThumbHover"  Color="#FFD4AF4B"/>

    <Style x:Key="ScrollbarThumbStyle" TargetType="Thumb">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Background" Value="{StaticResource ScrollbarThumb}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="3"
                            Margin="2 0"/>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource ScrollbarThumbHover}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DarkScrollBar" TargetType="ScrollBar">
        <Setter Property="Background" Value="{StaticResource ScrollbarTrack}"/>
        <Setter Property="Width" Value="10"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid Background="{TemplateBinding Background}">
                        <Track Name="PART_Track" IsDirectionReversed="True">
                            <Track.Thumb>
                                <Thumb Style="{StaticResource ScrollbarThumbStyle}"/>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Width" Value="Auto"/>
                <Setter Property="Height" Value="10"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="DarkScrollViewer" TargetType="ScrollViewer">
        <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
        <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollViewer">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ScrollContentPresenter Grid.Column="0"/>
                        <ScrollBar Grid.Column="1"
                                   Name="PART_VerticalScrollBar"
                                   Style="{StaticResource DarkScrollBar}"
                                   Value="{TemplateBinding VerticalOffset}"
                                   Maximum="{TemplateBinding ScrollableHeight}"
                                   ViewportSize="{TemplateBinding ViewportHeight}"
                                   Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ================================================================ -->
    <!--  ComboBox — dark gold-accented                                      -->
    <!-- ================================================================ -->
    <Style x:Key="DarkComboBox" TargetType="ComboBox">
        <Setter Property="Background" Value="{StaticResource BgElevated}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderDefault}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="12 8"/>
        <Setter Property="FontFamily" Value="{StaticResource FontBarlow}"/>
        <Setter Property="FontSize" Value="13"/>
    </Style>

    <!-- ================================================================ -->
    <!--  CheckBox (non-toggle default) — ivory-on-dark                     -->
    <!-- ================================================================ -->
    <Style TargetType="{x:Type CheckBox}">
        <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
        <Setter Property="FontFamily" Value="{StaticResource FontBarlow}"/>
        <Setter Property="FontSize" Value="13"/>
    </Style>

    <!-- ================================================================ -->
    <!--  RadioButton default                                                -->
    <!-- ================================================================ -->
    <Style TargetType="{x:Type RadioButton}">
        <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
        <Setter Property="FontFamily" Value="{StaticResource FontBarlow}"/>
        <Setter Property="FontSize" Value="13"/>
    </Style>

    <!-- ================================================================ -->
    <!--  ItemsControl activity row hover — used via BasedOn elsewhere       -->
    <!-- ================================================================ -->
    <Style x:Key="ActivityRow" TargetType="Border">
        <Setter Property="Background" Value="#08D4AF4B"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderDefault}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="18 14"/>
        <Setter Property="Margin" Value="0 0 0 4"/>
    </Style>

</ResourceDictionary>
