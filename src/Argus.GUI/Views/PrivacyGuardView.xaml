<UserControl x:Class="Argus.GUI.Views.PrivacyGuardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Argus.GUI.ViewModels">

    <ScrollViewer Style="{StaticResource DarkScrollViewer}">
        <StackPanel>

            <!-- ======================================================== -->
            <!--  Stat cards row                                           -->
            <!-- ======================================================== -->
            <UniformGrid Columns="3" Margin="0 0 0 24">
                <Border Style="{StaticResource StatCard}" Margin="0 0 14 0">
                    <StackPanel>
                        <TextBlock Style="{StaticResource StatLabel}" Text="▸  DENIED TODAY"/>
                        <TextBlock Style="{StaticResource StatValue}" Text="0" FontSize="30"/>
                        <TextBlock Style="{StaticResource StatFootText}" Text="Across all sensors"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCardB}" Margin="0 0 14 0">
                    <StackPanel>
                        <TextBlock Style="{StaticResource StatLabel}" Text="▸  ACTIVE GUARDS"/>
                        <TextBlock Style="{StaticResource StatValueGold}" Text="{Binding ActiveGuards}" FontSize="30"/>
                        <TextBlock Style="{StaticResource StatFootText}" Text="{Binding ActiveGuards, StringFormat='{}{0} guards enabled'}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCardCritical}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource StatLabel}" Text="▸  LAST ALERT"/>
                        <TextBlock Style="{StaticResource StatValueCritical}" Text="—" FontSize="30"/>
                        <TextBlock Style="{StaticResource StatFootText}" Text="No alerts"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- ======================================================== -->
            <!--  Action bar: Enable All / Disable All + Apply             -->
            <!-- ======================================================== -->
            <Grid Margin="0 0 0 10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" Grid.Column="0">
                    <Button Content="Enable All"  Style="{StaticResource SmallButton}" Command="{Binding EnableAllCommand}" Margin="0 0 6 0"/>
                    <Button Content="Disable All" Style="{StaticResource SmallButton}" Command="{Binding DisableAllCommand}" Margin="6 0 0 0"/>
                </StackPanel>

                <Button Grid.Column="2"
                        Content="Apply Privacy Settings"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding ApplySelectedCommand}"/>
            </Grid>

            <!-- Status message -->
            <TextBlock Text="{Binding StatusMessage}"
                       FontFamily="{StaticResource FontBarlow}"
                       FontSize="12"
                       Foreground="{StaticResource AccentGoldLight}"
                       Margin="0 0 0 10"/>

            <!-- ======================================================== -->
            <!--  Grouped toggle list with per-category enable/disable     -->
            <!-- ======================================================== -->
            <ItemsControl ItemsSource="{Binding GroupedToggles}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="0 0 0 18">
                            <!-- Category header with enable/disable buttons -->
                            <Grid Margin="0 0 0 10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="{Binding Key}" Style="{StaticResource CategoryHeader}" Margin="0"/>

                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Button Content="All On"
                                            Style="{StaticResource SmallButton}"
                                            Command="{Binding DataContext.EnableCategoryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding Key}"
                                            Margin="0 0 4 0"/>
                                    <Button Content="All Off"
                                            Style="{StaticResource SmallButton}"
                                            Command="{Binding DataContext.DisableCategoryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding Key}"/>
                                </StackPanel>
                            </Grid>
                            <Rectangle Height="1" Fill="{StaticResource GoldRule}" Margin="0 0 0 10"/>

                            <!-- Toggles in this category -->
                            <ItemsControl ItemsSource="{Binding}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource ToggleRow}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Margin="0 0 16 0">
                                                    <TextBlock Text="{Binding Name}" Style="{StaticResource ToggleRowTitle}"/>
                                                    <TextBlock Text="{Binding Description}" Style="{StaticResource ToggleRowSub}"/>
                                                </StackPanel>
                                                <CheckBox Grid.Column="1"
                                                          Style="{StaticResource ToggleSwitch}"
                                                          IsChecked="{Binding Enabled}"
                                                          ToolTip="{Binding WhatBreaks}"
                                                          VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </ScrollViewer>
</UserControl>
