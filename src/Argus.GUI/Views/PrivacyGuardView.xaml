<UserControl x:Class="Argus.GUI.Views.PrivacyGuardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Argus.GUI.ViewModels">

    <ScrollViewer Style="{StaticResource DarkScrollViewer}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ============================================================ -->
            <!-- Page header — Cinzel title + gold rule                       -->
            <!-- ============================================================ -->
            <StackPanel Grid.Row="0">
                <TextBlock Text="PRIVACY GUARD" Style="{StaticResource CinzelSectionTitle}"/>
                <TextBlock Text="Windows privacy hardening — toggle the lenses Argus watches through."
                           FontFamily="{StaticResource FontBarlow}"
                           FontSize="13"
                           Foreground="{StaticResource TextSecondary}"
                           Margin="0 6 0 0"/>
                <Rectangle Height="2" Margin="0 14 0 18" Fill="{StaticResource GoldRule}"/>
            </StackPanel>

            <!-- ============================================================ -->
            <!-- Action bar: Enable All / Disable All + Apply                  -->
            <!-- ============================================================ -->
            <Grid Grid.Row="1" Margin="0 0 0 10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" Grid.Column="0">
                    <Button Content="Enable All"  Style="{StaticResource SmallButton}" Margin="0 0 6 0"/>
                    <Button Content="Disable All" Style="{StaticResource SmallButton}" Margin="6 0 0 0"/>
                </StackPanel>

                <Button Grid.Column="2"
                        Content="Apply Privacy Settings"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding ApplySelectedCommand}"/>
            </Grid>

            <!-- Status message -->
            <TextBlock Grid.Row="2"
                       Text="{Binding StatusMessage}"
                       FontFamily="{StaticResource FontBarlow}"
                       FontSize="12"
                       Foreground="{StaticResource AccentGoldLight}"
                       Margin="0 0 0 10"/>

            <!-- ============================================================ -->
            <!-- Grouped toggle list                                           -->
            <!-- Outer item = IGrouping<string, GuardToggle>                   -->
            <!-- ============================================================ -->
            <ItemsControl Grid.Row="3" ItemsSource="{Binding GroupedToggles}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="0 0 0 18">
                            <!-- Category header -->
                            <TextBlock Text="{Binding Key}" Style="{StaticResource CategoryHeader}"/>
                            <Rectangle Height="1" Fill="{StaticResource GoldRule}" Margin="0 0 0 10"/>

                            <!-- Toggles in this category -->
                            <ItemsControl ItemsSource="{Binding}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource ToggleRow}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Title + description -->
                                                <StackPanel Grid.Column="0" Margin="0 0 16 0">
                                                    <TextBlock Text="{Binding Name}"
                                                               Style="{StaticResource ToggleRowTitle}"/>
                                                    <TextBlock Text="{Binding Description}"
                                                               Style="{StaticResource ToggleRowSub}"/>
                                                </StackPanel>

                                                <!-- Gold pill toggle -->
                                                <CheckBox Grid.Column="1"
                                                          Style="{StaticResource ToggleSwitch}"
                                                          IsChecked="{Binding Enabled}"
                                                          ToolTip="{Binding WhatBreaks}"
                                                          VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Footer apply -->
            <Border Grid.Row="4"
                    BorderBrush="{StaticResource BorderDefault}"
                    BorderThickness="0 1 0 0"
                    Padding="0 16 0 0"
                    Margin="0 18 0 0">
                <Button Content="Apply Changes"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding ApplySelectedCommand}"
                        HorizontalAlignment="Right"/>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
