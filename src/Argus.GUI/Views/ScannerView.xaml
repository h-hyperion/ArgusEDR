<UserControl x:Class="Argus.GUI.Views.ScannerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Argus.GUI.ViewModels">

    <ScrollViewer Style="{StaticResource DarkScrollViewer}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Page header -->
            <StackPanel Grid.Row="0">
                <TextBlock Text="SCANNER" Style="{StaticResource CinzelSectionTitle}"/>
                <TextBlock Text="Deep scan and file upload analysis"
                           FontFamily="{StaticResource FontBarlow}"
                           FontSize="13"
                           Foreground="{StaticResource TextSecondary}"
                           Margin="0 6 0 0"/>
                <Rectangle Height="2" Margin="0 14 0 18" Fill="{StaticResource GoldRule}"/>
            </StackPanel>

            <TabControl Grid.Row="1"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        Foreground="{StaticResource TextPrimary}">
                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="Background" Value="{StaticResource BgSurface}"/>
                        <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                        <Setter Property="FontFamily" Value="{StaticResource FontBarlowCondensed}"/>
                        <Setter Property="FontSize" Value="12"/>
                        <Setter Property="Padding" Value="22 10"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TabItem">
                                    <Border x:Name="bg"
                                            Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}"
                                            BorderBrush="{StaticResource BorderDefault}"
                                            BorderThickness="1 1 1 0"
                                            Margin="0 0 4 0">
                                        <ContentPresenter VerticalAlignment="Center"
                                                          HorizontalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="bg" Property="Background" Value="{StaticResource BgStatCard}"/>
                                            <Setter TargetName="bg" Property="BorderBrush" Value="{StaticResource AccentGold}"/>
                                            <Setter TargetName="bg" Property="BorderThickness" Value="1 2 1 0"/>
                                            <Setter Property="Foreground" Value="{StaticResource AccentGoldLight}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TabControl.Resources>

                <!-- Deep Scan Tab -->
                <TabItem Header="DEEP SCAN">
                    <Border Style="{StaticResource ContentCard}" Margin="0">
                        <StackPanel>
                            <TextBlock Text="—  SCAN TARGET  —" Style="{StaticResource CinzelSectionTitle}" FontSize="13" Margin="0 0 0 14"/>

                            <CheckBox Content="Scan user files"     Margin="0 0 0 8"/>
                            <CheckBox Content="Scan system files"   Margin="0 0 0 8"/>
                            <CheckBox Content="Scan registry"       Margin="0 0 0 8"/>
                            <CheckBox Content="Heuristic analysis"  Margin="0 0 0 16"/>

                            <Button Content="Start Scan"
                                    Style="{StaticResource PrimaryButton}"
                                    HorizontalAlignment="Left"
                                    Margin="0 8"/>

                            <Border Margin="0 24 0 0"
                                    Padding="20"
                                    Background="{StaticResource BgStatCard}"
                                    BorderBrush="{StaticResource BorderDefault}"
                                    BorderThickness="1">
                                <TextBlock Text="Scan results will appear here"
                                           FontFamily="{StaticResource FontBarlow}"
                                           FontSize="12"
                                           Foreground="{StaticResource TextMuted}"
                                           HorizontalAlignment="Center"/>
                            </Border>
                        </StackPanel>
                    </Border>
                </TabItem>

                <!-- Upload Tab -->
                <TabItem Header="UPLOAD">
                    <Border Style="{StaticResource ContentCard}" Margin="0">
                        <StackPanel>
                            <Border BorderBrush="{StaticResource AccentGold}"
                                    BorderThickness="2"
                                    Padding="40"
                                    Margin="0 0 0 16"
                                    Background="{StaticResource BgStatCard}">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="DROP FILES HERE"
                                               FontFamily="{StaticResource FontCinzel}"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource AccentGoldLight}"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="or click to browse"
                                               FontFamily="{StaticResource FontBarlow}"
                                               FontSize="12"
                                               Foreground="{StaticResource TextMuted}"
                                               Margin="0 6 0 0"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border Padding="20"
                                    Background="{StaticResource BgStatCard}"
                                    BorderBrush="{StaticResource BorderDefault}"
                                    BorderThickness="1">
                                <TextBlock Text="Uploaded files will appear here"
                                           FontFamily="{StaticResource FontBarlow}"
                                           FontSize="12"
                                           Foreground="{StaticResource TextMuted}"
                                           HorizontalAlignment="Center"/>
                            </Border>
                        </StackPanel>
                    </Border>
                </TabItem>
            </TabControl>
        </Grid>
    </ScrollViewer>
</UserControl>
