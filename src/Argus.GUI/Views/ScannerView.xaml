<UserControl x:Class="Argus.GUI.Views.ScannerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Argus.GUI.ViewModels">

    <ScrollViewer Style="{StaticResource DarkScrollViewer}">
        <StackPanel>

            <!-- ======================================================== -->
            <!--  DEEP SCAN — feature panel with gold border + glow       -->
            <!--  Matches the HTML mockup's .panel-feature treatment.     -->
            <!-- ======================================================== -->
            <Border Style="{StaticResource FeaturePanel}" Margin="0 0 0 18">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Deep Scan"
                                   FontFamily="{StaticResource FontCinzel}"
                                   FontSize="24" FontWeight="Medium"
                                   Foreground="{StaticResource AccentGoldLight}"/>
                        <TextBlock Text="YARA · AMSI · BEHAVIORAL · THREAT INTEL CROSS-REFERENCE"
                                   FontFamily="{StaticResource FontBarlowCondensed}"
                                   FontSize="12" FontWeight="Medium"
                                   Foreground="{StaticResource TextMuted}"
                                   Margin="0 6 0 20"/>

                        <!-- Scan targets: 2-column grid matching mockup -->
                        <UniformGrid Columns="2" Rows="2">
                            <Border Background="#40000000"
                                    BorderBrush="{StaticResource BorderDefault}"
                                    BorderThickness="1" Padding="16 12" Margin="0 0 10 10">
                                <DockPanel>
                                    <CheckBox DockPanel.Dock="Left"
                                              IsChecked="{Binding ScanUserFiles}"
                                              VerticalAlignment="Center" Margin="0 0 14 0"/>
                                    <TextBlock DockPanel.Dock="Right" VerticalAlignment="Center"
                                               FontFamily="{StaticResource FontBarlowCondensed}"
                                               FontSize="11" Foreground="{StaticResource AccentGold}"
                                               HorizontalAlignment="Right"
                                               Text="62 GB"/>
                                    <TextBlock Text="User profile"
                                               FontFamily="{StaticResource FontBarlow}" FontSize="13"
                                               Foreground="{StaticResource TextSecondary}"
                                               VerticalAlignment="Center"/>
                                </DockPanel>
                            </Border>
                            <Border Background="#40000000"
                                    BorderBrush="{StaticResource BorderDefault}"
                                    BorderThickness="1" Padding="16 12" Margin="0 0 0 10">
                                <DockPanel>
                                    <CheckBox DockPanel.Dock="Left"
                                              IsChecked="{Binding ScanSystemFiles}"
                                              VerticalAlignment="Center" Margin="0 0 14 0"/>
                                    <TextBlock DockPanel.Dock="Right" VerticalAlignment="Center"
                                               FontFamily="{StaticResource FontBarlowCondensed}"
                                               FontSize="11" Foreground="{StaticResource AccentGold}"
                                               HorizontalAlignment="Right"/>
                                    <TextBlock Text="System files"
                                               FontFamily="{StaticResource FontBarlow}" FontSize="13"
                                               Foreground="{StaticResource TextSecondary}"
                                               VerticalAlignment="Center"/>
                                </DockPanel>
                            </Border>
                            <Border Background="#40000000"
                                    BorderBrush="{StaticResource BorderDefault}"
                                    BorderThickness="1" Padding="16 12" Margin="0 0 10 0">
                                <DockPanel>
                                    <CheckBox DockPanel.Dock="Left"
                                              IsChecked="{Binding ScanRegistry}"
                                              VerticalAlignment="Center" Margin="0 0 14 0"/>
                                    <TextBlock DockPanel.Dock="Right" VerticalAlignment="Center"
                                               FontFamily="{StaticResource FontBarlowCondensed}"
                                               FontSize="11" Foreground="{StaticResource AccentGold}"
                                               HorizontalAlignment="Right"
                                               Text="—"/>
                                    <TextBlock Text="Registry"
                                               FontFamily="{StaticResource FontBarlow}" FontSize="13"
                                               Foreground="{StaticResource TextSecondary}"
                                               VerticalAlignment="Center"/>
                                </DockPanel>
                            </Border>
                            <Border Background="#40000000"
                                    BorderBrush="{StaticResource BorderDefault}"
                                    BorderThickness="1" Padding="16 12">
                                <DockPanel>
                                    <CheckBox DockPanel.Dock="Left"
                                              IsChecked="{Binding HeuristicAnalysis}"
                                              VerticalAlignment="Center" Margin="0 0 14 0"/>
                                    <TextBlock DockPanel.Dock="Right" VerticalAlignment="Center"
                                               FontFamily="{StaticResource FontBarlowCondensed}"
                                               FontSize="11" Foreground="{StaticResource AccentGold}"
                                               HorizontalAlignment="Right"
                                               Text="—"/>
                                    <TextBlock Text="Heuristic analysis"
                                               FontFamily="{StaticResource FontBarlow}" FontSize="13"
                                               Foreground="{StaticResource TextSecondary}"
                                               VerticalAlignment="Center"/>
                                </DockPanel>
                            </Border>
                        </UniformGrid>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Content="Begin Scan"
                            Style="{StaticResource ReviewButton}"
                            Command="{Binding StartScanCommand}"
                            VerticalAlignment="Top"
                            Margin="24 0 0 0"/>
                </Grid>
            </Border>

            <!-- Progress bar (visible during scan) -->
            <Border Background="{StaticResource BgStatCard}"
                    BorderBrush="{StaticResource BorderDefault}"
                    BorderThickness="1"
                    ClipToBounds="True"
                    Height="4" Margin="0 0 0 8">
                <ProgressBar Value="{Binding ScanProgress}"
                             Minimum="0" Maximum="100"
                             Background="Transparent"
                             Foreground="{StaticResource AccentGold}"
                             BorderThickness="0"/>
            </Border>

            <!-- Scan status text -->
            <TextBlock Text="{Binding Status}"
                       FontFamily="{StaticResource FontBarlow}"
                       FontSize="12"
                       Foreground="{StaticResource TextSecondary}"
                       Margin="0 0 0 18"/>

            <!-- ======================================================== -->
            <!--  Stat cards row                                           -->
            <!-- ======================================================== -->
            <UniformGrid Columns="3" Margin="0 0 0 28">
                <Border Style="{StaticResource StatCard}" Margin="0 0 14 0">
                    <StackPanel>
                        <TextBlock Style="{StaticResource StatLabel}" Text="▸  LAST FULL SCAN"/>
                        <TextBlock Style="{StaticResource StatValue}" Text="—" FontSize="30"/>
                        <TextBlock Style="{StaticResource StatFootText}" Text="No scans yet"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCardB}" Margin="0 0 14 0">
                    <StackPanel>
                        <TextBlock Style="{StaticResource StatLabel}" Text="▸  YARA RULES"/>
                        <TextBlock Style="{StaticResource StatValueGold}" Text="0" FontSize="30"/>
                        <TextBlock Style="{StaticResource StatFootText}" Text="Awaiting sync"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCardCritical}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource StatLabel}" Text="▸  AVG SCAN TIME"/>
                        <TextBlock Style="{StaticResource StatValueCritical}" Text="—" FontSize="30"/>
                        <TextBlock Style="{StaticResource StatFootText}" Text="No data"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- ======================================================== -->
            <!--  Recent Scans (matches HTML mockup)                       -->
            <!-- ======================================================== -->
            <TextBlock Text="—  RECENT SCANS  —" Style="{StaticResource CinzelSectionTitle}" FontSize="13" Margin="0 0 0 12"/>

            <ItemsControl>
                <ItemsControl.Items>
                    <Border Style="{StaticResource ActivityRow}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Margin="0 0 16 0"
                                    BorderBrush="{StaticResource StatusGreen}"
                                    BorderThickness="1" Padding="10 4">
                                <TextBlock FontFamily="{StaticResource FontBarlowCondensed}" FontSize="10"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource StatusGreen}" Text="COMPLETE"/>
                            </Border>
                            <TextBlock Grid.Column="1" VerticalAlignment="Center"
                                       FontFamily="{StaticResource FontBarlow}" FontSize="13"
                                       Foreground="{StaticResource TextSecondary}"
                                       Text="Full system scan"/>
                            <TextBlock Grid.Column="2" VerticalAlignment="Center"
                                       FontFamily="{StaticResource FontBarlowCondensed}" FontSize="11"
                                       Foreground="{StaticResource TextMuted}"
                                       Text="2D AGO · 14:08"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource ActivityRow}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Margin="0 0 16 0"
                                    BorderBrush="{StaticResource StatusGreen}"
                                    BorderThickness="1" Padding="10 4">
                                <TextBlock FontFamily="{StaticResource FontBarlowCondensed}" FontSize="10"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource StatusGreen}" Text="COMPLETE"/>
                            </Border>
                            <TextBlock Grid.Column="1" VerticalAlignment="Center"
                                       FontFamily="{StaticResource FontBarlow}" FontSize="13"
                                       Foreground="{StaticResource TextSecondary}"
                                       Text="Downloads quick scan"/>
                            <TextBlock Grid.Column="2" VerticalAlignment="Center"
                                       FontFamily="{StaticResource FontBarlowCondensed}" FontSize="11"
                                       Foreground="{StaticResource TextMuted}"
                                       Text="3D AGO · 01:22"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource ActivityRow}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Margin="0 0 16 0"
                                    BorderBrush="{StaticResource AccentGoldLight}"
                                    BorderThickness="1" Padding="10 4">
                                <TextBlock FontFamily="{StaticResource FontBarlowCondensed}" FontSize="10"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource AccentGoldLight}" Text="PARTIAL"/>
                            </Border>
                            <TextBlock Grid.Column="1" VerticalAlignment="Center"
                                       FontFamily="{StaticResource FontBarlow}" FontSize="13"
                                       Foreground="{StaticResource TextSecondary}"
                                       Text="USB mount scan — 1 warning"/>
                            <TextBlock Grid.Column="2" VerticalAlignment="Center"
                                       FontFamily="{StaticResource FontBarlowCondensed}" FontSize="11"
                                       Foreground="{StaticResource TextMuted}"
                                       Text="5D AGO · 04:51"/>
                        </Grid>
                    </Border>
                </ItemsControl.Items>
            </ItemsControl>

            <!-- ======================================================== -->
            <!--  File Upload (secondary section)                          -->
            <!-- ======================================================== -->
            <TextBlock Text="—  FILE UPLOAD  —" Style="{StaticResource CinzelSectionTitle}" FontSize="13" Margin="0 24 0 12"/>

            <Border Style="{StaticResource ContentCard}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               FontFamily="{StaticResource FontBarlow}" FontSize="13"
                               Foreground="{StaticResource TextSecondary}"
                               Text="Select individual files for targeted analysis"
                               VerticalAlignment="Center"/>
                    <Button Grid.Column="1"
                            Content="Browse Files"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding BrowseFilesCommand}"
                            VerticalAlignment="Center"/>
                </Grid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
