<UserControl x:Class="Argus.GUI.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Argus.GUI.ViewModels">

    <ScrollViewer Style="{StaticResource DarkScrollViewer}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Page header -->
            <StackPanel Grid.Row="0">
                <TextBlock Text="SETTINGS" Style="{StaticResource CinzelSectionTitle}"/>
                <TextBlock Text="DNS, API keys, and update policy"
                           FontFamily="{StaticResource FontBarlow}"
                           FontSize="13"
                           Foreground="{StaticResource TextSecondary}"
                           Margin="0 6 0 0"/>
                <Rectangle Height="2" Margin="0 14 0 18" Fill="{StaticResource GoldRule}"/>
            </StackPanel>

            <TabControl Grid.Row="1"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        Foreground="{StaticResource TextPrimary}">
                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="Background" Value="{StaticResource BgSurface}"/>
                        <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                        <Setter Property="FontFamily" Value="{StaticResource FontBarlowCondensed}"/>
                        <Setter Property="FontSize" Value="12"/>
                        <Setter Property="Padding" Value="22 10"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TabItem">
                                    <Border x:Name="bg"
                                            Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}"
                                            BorderBrush="{StaticResource BorderDefault}"
                                            BorderThickness="1 1 1 0"
                                            Margin="0 0 4 0">
                                        <ContentPresenter VerticalAlignment="Center"
                                                          HorizontalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="bg" Property="Background" Value="{StaticResource BgStatCard}"/>
                                            <Setter TargetName="bg" Property="BorderBrush" Value="{StaticResource AccentGold}"/>
                                            <Setter TargetName="bg" Property="BorderThickness" Value="1 2 1 0"/>
                                            <Setter Property="Foreground" Value="{StaticResource AccentGoldLight}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TabControl.Resources>

                <!-- General Tab -->
                <TabItem Header="GENERAL" IsSelected="True">
                    <Border Style="{StaticResource ContentCard}" Margin="0">
                        <StackPanel>
                            <TextBlock Text="—  GENERAL SETTINGS  —"
                                       Style="{StaticResource CinzelSectionTitle}"
                                       FontSize="13"
                                       Margin="0 0 0 16"/>

                            <Border Style="{StaticResource ToggleRow}" Margin="0 0 0 8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0 0 16 0">
                                        <TextBlock Text="Launch Argus at startup"
                                                   Style="{StaticResource ToggleRowTitle}"/>
                                        <TextBlock Text="Start minimized to system tray when you log in"
                                                   Style="{StaticResource ToggleRowSub}"/>
                                    </StackPanel>
                                    <CheckBox Grid.Column="1"
                                              Style="{StaticResource ToggleSwitch}"
                                              IsChecked="{Binding LaunchAtStartup}"
                                              VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>
                </TabItem>

                <!-- DNS Tab -->
                <TabItem Header="DNS">
                    <Border Style="{StaticResource ContentCard}" Margin="0">
                        <StackPanel>
                            <TextBlock Text="—  DNS CONFIGURATION  —"
                                       Style="{StaticResource CinzelSectionTitle}"
                                       FontSize="13"
                                       Margin="0 0 0 16"/>

                            <TextBlock Text="PROFILE"
                                       FontFamily="{StaticResource FontBarlowCondensed}"
                                       FontSize="11"
                                       FontWeight="Medium"
                                       Foreground="{StaticResource AccentGold}"
                                       Margin="0 0 0 6"/>
                            <ComboBox ItemsSource="{Binding DnsProfiles}"
                                      SelectedItem="{Binding SelectedDnsProfile}"
                                      DisplayMemberPath="Name"
                                      Style="{DynamicResource DarkComboBox}"
                                      Margin="0 0 0 18"/>

                            <TextBlock Text="PRIMARY DNS"
                                       FontFamily="{StaticResource FontBarlowCondensed}"
                                       FontSize="11"
                                       FontWeight="Medium"
                                       Foreground="{StaticResource AccentGold}"
                                       Margin="0 0 0 6"/>
                            <TextBlock Text="{Binding SelectedDnsProfile.Primary}"
                                       FontFamily="{StaticResource FontCinzel}"
                                       FontSize="16"
                                       Foreground="{StaticResource TextPrimary}"
                                       Margin="0 0 0 18"/>

                            <TextBlock Text="SECONDARY DNS"
                                       FontFamily="{StaticResource FontBarlowCondensed}"
                                       FontSize="11"
                                       FontWeight="Medium"
                                       Foreground="{StaticResource AccentGold}"
                                       Margin="0 0 0 6"/>
                            <TextBlock Text="{Binding SelectedDnsProfile.Secondary}"
                                       FontFamily="{StaticResource FontCinzel}"
                                       FontSize="16"
                                       Foreground="{StaticResource TextPrimary}"
                                       Margin="0 0 0 18"/>

                            <Button Content="Apply DNS Settings"
                                    Style="{StaticResource PrimaryButton}"
                                    Command="{Binding ApplyDnsCommand}"
                                    HorizontalAlignment="Left"
                                    Margin="0 12 0 0"/>
                        </StackPanel>
                    </Border>
                </TabItem>

                <!-- API Keys Tab -->
                <TabItem Header="API KEYS">
                    <Border Style="{StaticResource ContentCard}" Margin="0">
                        <StackPanel>
                            <TextBlock Text="—  SERVICE API KEYS  —"
                                       Style="{StaticResource CinzelSectionTitle}"
                                       FontSize="13"
                                       Margin="0 0 0 16"/>

                            <Border Background="{StaticResource BgStatCard}"
                                    BorderBrush="{StaticResource BorderDefault}"
                                    BorderThickness="1"
                                    Padding="20 14"
                                    Margin="0 0 0 16">
                                <TextBlock Text="VirusTotal — Not configured"
                                           FontFamily="{StaticResource FontBarlow}"
                                           FontSize="12"
                                           Foreground="{StaticResource TextMuted}"/>
                            </Border>

                            <Button Content="Add Key"
                                    Style="{StaticResource SecondaryButton}"
                                    HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Border>
                </TabItem>

                <!-- Auto-Update Tab -->
                <TabItem Header="AUTO-UPDATE">
                    <Border Style="{StaticResource ContentCard}" Margin="0">
                        <StackPanel>
                            <TextBlock Text="—  UPDATE POLICY  —"
                                       Style="{StaticResource CinzelSectionTitle}"
                                       FontSize="13"
                                       Margin="0 0 0 16"/>

                            <StackPanel Margin="0 0 0 8">
                                <RadioButton Content="Minor updates only"
                                             Margin="0 6"
                                             GroupName="UpdatePolicy"/>
                                <RadioButton Content="Minor and major updates"
                                             Margin="0 6"
                                             GroupName="UpdatePolicy"/>
                                <RadioButton Content="Critical only"
                                             Margin="0 6"
                                             GroupName="UpdatePolicy"/>
                            </StackPanel>

                            <Button Content="Save Policy"
                                    Style="{StaticResource PrimaryButton}"
                                    HorizontalAlignment="Left"
                                    Margin="0 16 0 0"/>
                        </StackPanel>
                    </Border>
                </TabItem>
            </TabControl>
        </Grid>
    </ScrollViewer>
</UserControl>
