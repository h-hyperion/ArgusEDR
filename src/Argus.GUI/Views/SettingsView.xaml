<UserControl x:Class="Argus.GUI.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Argus.GUI.ViewModels">

    <ScrollViewer Style="{StaticResource DarkScrollViewer}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Page Header -->
            <StackPanel>
                <TextBlock Text="Settings" FontSize="24" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimary}"/>
                <TextBlock Text="DNS, API keys, and update policy" FontSize="13"
                           Foreground="{StaticResource TextMuted}" Margin="0 4 0 0"/>
                <Border Height="1" Background="{StaticResource BorderDefault}" Margin="0 16"/>
            </StackPanel>

            <TabControl Grid.Row="1" Margin="0" Background="Transparent"
                        BorderBrush="Transparent" Foreground="{StaticResource TextPrimary}">
                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="Background" Value="{StaticResource BgSurface}"/>
                        <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                        <Setter Property="Padding" Value="20 10"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TabItem">
                                    <Border x:Name="bg" Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}"
                                            CornerRadius="8 8 0 0"
                                            Margin="0 0 4 0">
                                        <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="bg" Property="Background" Value="{StaticResource BgElevated}"/>
                                            <Setter TargetName="bg" Property="BorderBrush" Value="{StaticResource AccentGold}"/>
                                            <Setter TargetName="bg" Property="BorderThickness" Value="0 2 0 0"/>
                                            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TabControl.Resources>

                <!-- General Tab -->
                <TabItem Header="General" IsSelected="True">
                    <Border Style="{StaticResource ContentCard}" Margin="0" BorderThickness="0">
                        <StackPanel>
                            <TextBlock Text="General Settings" FontSize="14" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimary}" Margin="0 0 0 16"/>

                            <Border Background="{StaticResource BgElevated}" Padding="16"
                                    CornerRadius="8" Margin="0 0 0 12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Launch Argus at startup" FontSize="13"
                                                   Foreground="{StaticResource TextPrimary}"/>
                                        <TextBlock Text="Start minimized to system tray when you log in"
                                                   FontSize="11" Foreground="{StaticResource TextMuted}"
                                                   Margin="0 4 0 0"/>
                                    </StackPanel>
                                    <CheckBox Grid.Column="1" IsChecked="{Binding LaunchAtStartup}"
                                              VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>
                </TabItem>

                <!-- DNS Tab -->
                <TabItem Header="DNS">
                    <Border Style="{StaticResource ContentCard}" Margin="0" BorderThickness="0">
                        <StackPanel>
                            <TextBlock Text="DNS Configuration" FontSize="14" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimary}" Margin="0 0 0 16"/>

                            <TextBlock Text="Profile" FontSize="12" Foreground="{StaticResource TextSecondary}"
                                       Margin="0 0 0 4"/>
                            <ComboBox ItemsSource="{Binding DnsProfiles.SelectedItem.Name}"
                                      DisplayMemberPath="Name"
                                      Style="{DynamicResource DarkComboBox}" Margin="0 0 0 16"/>

                            <TextBlock Text="Primary DNS" FontSize="12" Foreground="{StaticResource TextSecondary}"
                                       Margin="0 0 0 4"/>
                            <TextBlock Text="{Binding SelectedDnsProfile.Primary}" FontSize="14"
                                       Foreground="{StaticResource TextPrimary}" Margin="0 0 0 16"/>

                            <TextBlock Text="Secondary DNS" FontSize="12" Foreground="{StaticResource TextSecondary}"
                                       Margin="0 0 0 4"/>
                            <TextBlock Text="{Binding SelectedDnsProfile.Secondary}" FontSize="14"
                                       Foreground="{StaticResource TextPrimary}" Margin="0 0 0 16"/>

                            <Button Content="Apply DNS Settings" Style="{StaticResource PrimaryButton}"
                                    Command="{Binding ApplyDnsCommand}"
                                    HorizontalAlignment="Left" Margin="0 16 0 0"/>
                        </StackPanel>
                    </Border>
                </TabItem>

                <!-- API Keys Tab -->
                <TabItem Header="API Keys">
                    <Border Style="{StaticResource ContentCard}" Margin="0" BorderThickness="0">
                        <StackPanel>
                            <TextBlock Text="Service API Keys" FontSize="14" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimary}" Margin="0 0 0 16"/>

                            <Border Background="{StaticResource BgElevated}" Padding="16"
                                    CornerRadius="8" Margin="0 0 0 16">
                                <TextBlock Text="VirusTotal - Not configured" FontSize="12"
                                           Foreground="{StaticResource TextMuted}"/>
                            </Border>

                            <Button Content="Add Key" Style="{StaticResource SecondaryButton}"
                                    HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Border>
                </TabItem>

                <!-- Auto-Update Tab -->
                <TabItem Header="Auto-Update">
                    <Border Style="{StaticResource ContentCard}" Margin="0" BorderThickness="0">
                        <StackPanel>
                            <TextBlock Text="Update Policy" FontSize="14" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimary}" Margin="0 0 0 16"/>

                            <StackPanel Margin="0 0 0 8">
                                <RadioButton Content="Minor updates only" Foreground="{StaticResource TextPrimary}"
                                             Margin="0 4" GroupName="UpdatePolicy"/>
                                <RadioButton Content="Minor and major updates" Foreground="{StaticResource TextPrimary}"
                                             Margin="0 4" GroupName="UpdatePolicy"/>
                                <RadioButton Content="Critical only" Foreground="{StaticResource TextPrimary}"
                                             Margin="0 4" GroupName="UpdatePolicy"/>
                            </StackPanel>

                            <Button Content="Save Policy" Style="{StaticResource PrimaryButton}"
                                    HorizontalAlignment="Left" Margin="0 16 0 0"/>
                        </StackPanel>
                    </Border>
                </TabItem>
            </TabControl>
        </Grid>
    </ScrollViewer>
</UserControl>
