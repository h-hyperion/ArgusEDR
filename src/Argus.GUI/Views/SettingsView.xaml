<UserControl x:Class="Argus.GUI.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Argus.GUI.ViewModels">

    <ScrollViewer Style="{StaticResource DarkScrollViewer}">
        <StackPanel>

            <!-- ======================================================== -->
            <!--  General — toggle rows matching mockup                   -->
            <!-- ======================================================== -->
            <TextBlock Text="—  GENERAL  —" Style="{StaticResource CinzelSectionTitle}" FontSize="13" Margin="0 0 0 12"/>

            <!-- Start with Windows -->
            <Border Style="{StaticResource ToggleRow}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0 0 16 0">
                        <TextBlock Text="Start with Windows" Style="{StaticResource ToggleRowTitle}"/>
                        <TextBlock Text="Watchdog service autostart" Style="{StaticResource ToggleRowSub}"/>
                    </StackPanel>
                    <CheckBox Grid.Column="1"
                              Style="{StaticResource ToggleSwitch}"
                              IsChecked="{Binding LaunchAtStartup}"
                              VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Telemetry -->
            <Border Style="{StaticResource ToggleRow}" Opacity="0.6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0 0 16 0">
                        <TextBlock Text="Telemetry" Style="{StaticResource ToggleRowTitle}"/>
                        <TextBlock Text="Permanently disabled — Argus phones home to nobody" Style="{StaticResource ToggleRowSub}"/>
                    </StackPanel>
                    <CheckBox Grid.Column="1"
                              Style="{StaticResource ToggleSwitch}"
                              IsChecked="False" IsEnabled="False"
                              VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Automatic signature updates -->
            <Border Style="{StaticResource ToggleRow}" Margin="0 0 0 28">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0 0 16 0">
                        <TextBlock Text="Automatic signature updates" Style="{StaticResource ToggleRowTitle}"/>
                        <TextBlock Text="YARA + Sigma + threat intel feeds" Style="{StaticResource ToggleRowSub}"/>
                    </StackPanel>
                    <CheckBox Grid.Column="1"
                              Style="{StaticResource ToggleSwitch}"
                              IsChecked="True"
                              VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- ======================================================== -->
            <!--  About — feature panel matching mockup                   -->
            <!-- ======================================================== -->
            <TextBlock Text="—  ABOUT  —" Style="{StaticResource CinzelSectionTitle}" FontSize="13" Margin="0 0 0 12"/>

            <Border Style="{StaticResource FeaturePanel}" Margin="0 0 0 28">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Argus EDR"
                                   FontFamily="{StaticResource FontCinzel}"
                                   FontSize="24" FontWeight="Medium"
                                   Foreground="{StaticResource AccentGoldLight}"/>
                        <TextBlock FontFamily="{StaticResource FontBarlowCondensed}"
                                   FontSize="12" FontWeight="Medium"
                                   Foreground="{StaticResource TextMuted}"
                                   Margin="0 6 0 0"
                                   Text="VERSION 2.1.1 · ENGINE BUILD 2111 · MIT LICENSE"/>
                        <TextBlock FontFamily="{StaticResource FontBarlowCondensed}"
                                   FontSize="12" FontWeight="Medium"
                                   Foreground="{StaticResource TextMuted}"
                                   Margin="0 2 0 0"
                                   Text="USER-MODE C# ON .NET 8 · FREE AND OPEN SOURCE FOREVER"/>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Content="Check for Updates"
                            Style="{StaticResource SecondaryButton}"
                            VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- ======================================================== -->
            <!--  DNS Configuration                                        -->
            <!-- ======================================================== -->
            <TextBlock Text="—  DNS CONFIGURATION  —" Style="{StaticResource CinzelSectionTitle}" FontSize="13" Margin="0 0 0 12"/>

            <Border Style="{StaticResource ContentCard}" Margin="0 0 0 28">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Column="0" Grid.Row="0">
                        <TextBlock Text="PROFILE"
                                   FontFamily="{StaticResource FontBarlowCondensed}"
                                   FontSize="11" FontWeight="Medium"
                                   Foreground="{StaticResource AccentGold}"
                                   Margin="0 0 0 6"/>
                        <ComboBox ItemsSource="{Binding DnsProfiles}"
                                  SelectedItem="{Binding SelectedDnsProfile}"
                                  Style="{DynamicResource DarkComboBox}"
                                  Width="260"
                                  HorizontalAlignment="Left">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}"
                                               FontFamily="{StaticResource FontBarlow}"
                                               FontSize="13"
                                               Foreground="{StaticResource TextPrimary}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <Button Grid.Column="1" Grid.Row="0"
                            Content="Apply DNS Settings"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding ApplyDnsCommand}"
                            VerticalAlignment="Bottom"/>

                    <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0 16 0 0">
                        <StackPanel Margin="0 0 48 0">
                            <TextBlock Text="PRIMARY DNS"
                                       FontFamily="{StaticResource FontBarlowCondensed}"
                                       FontSize="10" FontWeight="Medium"
                                       Foreground="{StaticResource AccentGold}"
                                       Margin="0 0 0 4"/>
                            <TextBlock Text="{Binding SelectedDnsProfile.Primary}"
                                       FontFamily="{StaticResource FontCinzel}"
                                       FontSize="15"
                                       Foreground="{StaticResource TextPrimary}"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="SECONDARY DNS"
                                       FontFamily="{StaticResource FontBarlowCondensed}"
                                       FontSize="10" FontWeight="Medium"
                                       Foreground="{StaticResource AccentGold}"
                                       Margin="0 0 0 4"/>
                            <TextBlock Text="{Binding SelectedDnsProfile.Secondary}"
                                       FontFamily="{StaticResource FontCinzel}"
                                       FontSize="15"
                                       Foreground="{StaticResource TextPrimary}"/>
                        </StackPanel>
                    </StackPanel>

                    <TextBlock Grid.Row="2" Grid.ColumnSpan="2"
                               Text="{Binding StatusMessage}"
                               FontFamily="{StaticResource FontBarlow}"
                               FontSize="11"
                               Foreground="{StaticResource AccentGoldLight}"
                               Margin="0 12 0 0"/>
                </Grid>
            </Border>

            <!-- ======================================================== -->
            <!--  API Keys                                                 -->
            <!-- ======================================================== -->
            <TextBlock Text="—  SERVICE API KEYS  —" Style="{StaticResource CinzelSectionTitle}" FontSize="13" Margin="0 0 0 12"/>

            <StackPanel Margin="0 0 0 28">
                <Border Style="{StaticResource ContentCard}" Margin="0 0 0 8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{Binding VirusTotalKeyStatus}"
                                   FontFamily="{StaticResource FontBarlow}"
                                   FontSize="12"
                                   Foreground="{StaticResource TextMuted}"
                                   VerticalAlignment="Center"/>
                        <Button Grid.Column="1"
                                Content="Add Key"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding AddApiKeyCommand}"
                                CommandParameter="VirusTotal"/>
                    </Grid>
                </Border>
                <Border Style="{StaticResource ContentCard}" Margin="0 0 0 8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{Binding AbuseIpdbKeyStatus}"
                                   FontFamily="{StaticResource FontBarlow}"
                                   FontSize="12"
                                   Foreground="{StaticResource TextMuted}"
                                   VerticalAlignment="Center"/>
                        <Button Grid.Column="1"
                                Content="Add Key"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding AddApiKeyCommand}"
                                CommandParameter="AbuseIPDB"/>
                    </Grid>
                </Border>
                <TextBlock Text="{Binding ApiKeyStatusMessage}"
                           FontFamily="{StaticResource FontBarlow}"
                           FontSize="11"
                           Foreground="{StaticResource AccentGoldLight}"
                           Margin="4 4 0 0"/>
            </StackPanel>

            <!-- ======================================================== -->
            <!--  Update Policy                                            -->
            <!-- ======================================================== -->
            <TextBlock Text="—  UPDATE POLICY  —" Style="{StaticResource CinzelSectionTitle}" FontSize="13" Margin="0 0 0 12"/>

            <Border Style="{StaticResource ContentCard}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <RadioButton Content="Critical updates only" Margin="0 4" GroupName="UpdatePolicy"/>
                        <RadioButton Content="Minor and major updates" Margin="0 4" GroupName="UpdatePolicy" IsChecked="True"/>
                        <RadioButton Content="All updates (including pre-release)" Margin="0 4" GroupName="UpdatePolicy"/>
                    </StackPanel>
                    <Button Grid.Column="1"
                            Content="Save Policy"
                            Style="{StaticResource PrimaryButton}"
                            VerticalAlignment="Top"/>
                </Grid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
