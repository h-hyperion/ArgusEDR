<UserControl x:Class="Argus.GUI.Views.QuarantineView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Argus.GUI.ViewModels">

    <ScrollViewer Style="{StaticResource DarkScrollViewer}">
        <StackPanel>

            <!-- ======================================================== -->
            <!--  Stat cards row                                           -->
            <!-- ======================================================== -->
            <UniformGrid Columns="3" Margin="0 0 0 28">
                <Border Style="{StaticResource StatCard}" Margin="0 0 14 0">
                    <StackPanel>
                        <TextBlock Style="{StaticResource StatLabel}" Text="▸  ITEMS CONTAINED"/>
                        <TextBlock Style="{StaticResource StatValue}" Text="{Binding ItemCount}" FontSize="30"/>
                        <TextBlock Style="{StaticResource StatFootText}" Text="AES-256-GCM encrypted"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCardB}" Margin="0 0 14 0">
                    <StackPanel>
                        <TextBlock Style="{StaticResource StatLabel}" Text="▸  STORAGE USED"/>
                        <TextBlock Style="{StaticResource StatValueGold}" Text="0 MB" FontSize="30"/>
                        <TextBlock Style="{StaticResource StatFootText}" Text="Of 1 GB limit"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCardCritical}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource StatLabel}" Text="▸  OLDEST"/>
                        <TextBlock Style="{StaticResource StatValueCritical}" Text="—" FontSize="30"/>
                        <TextBlock Style="{StaticResource StatFootText}" Text="Auto-purge at 30d"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- ======================================================== -->
            <!--  Quarantined Files — matching mockup activity rows        -->
            <!-- ======================================================== -->
            <TextBlock Text="—  QUARANTINED FILES  —" Style="{StaticResource CinzelSectionTitle}" FontSize="13" Margin="0 0 0 12"/>

            <!-- Status -->
            <Border Style="{StaticResource ContentCard}" Padding="20 14" Margin="0 0 0 12">
                <TextBlock Text="{Binding StatusMessage}"
                           FontFamily="{StaticResource FontBarlow}"
                           FontSize="12"
                           Foreground="{StaticResource AccentGoldLight}"
                           HorizontalAlignment="Center"/>
            </Border>

            <!-- Quarantine file list (placeholder rows matching mockup) -->
            <ItemsControl>
                <ItemsControl.Items>
                    <Border Style="{StaticResource ActivityRow}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Margin="0 0 16 0"
                                    BorderBrush="{StaticResource AccentRedCritical}"
                                    BorderThickness="1" Padding="10 4">
                                <TextBlock FontFamily="{StaticResource FontBarlowCondensed}" FontSize="10"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource AccentRedCritical}" Text="TROJAN"/>
                            </Border>
                            <TextBlock Grid.Column="1" VerticalAlignment="Center"
                                       FontFamily="{StaticResource FontBarlow}" FontSize="13"
                                       Foreground="{StaticResource TextSecondary}"
                                       Text="suspicious_script.ps1"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Grid.Column="2" VerticalAlignment="Center"
                                       FontFamily="{StaticResource FontBarlowCondensed}" FontSize="11"
                                       Foreground="{StaticResource TextMuted}"
                                       Margin="16 0 0 0"
                                       Text="14 MIN AGO"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource ActivityRow}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Margin="0 0 16 0"
                                    BorderBrush="{StaticResource AccentGoldLight}"
                                    BorderThickness="1" Padding="10 4">
                                <TextBlock FontFamily="{StaticResource FontBarlowCondensed}" FontSize="10"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource AccentGoldLight}" Text="BYOVD"/>
                            </Border>
                            <TextBlock Grid.Column="1" VerticalAlignment="Center"
                                       FontFamily="{StaticResource FontBarlow}" FontSize="13"
                                       Foreground="{StaticResource TextSecondary}"
                                       Text="unsigned_driver.sys"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Grid.Column="2" VerticalAlignment="Center"
                                       FontFamily="{StaticResource FontBarlowCondensed}" FontSize="11"
                                       Foreground="{StaticResource TextMuted}"
                                       Margin="16 0 0 0"
                                       Text="1 HOUR AGO"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource ActivityRow}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Margin="0 0 16 0"
                                    BorderBrush="{StaticResource AccentRedCritical}"
                                    BorderThickness="1" Padding="10 4">
                                <TextBlock FontFamily="{StaticResource FontBarlowCondensed}" FontSize="10"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource AccentRedCritical}" Text="YARA"/>
                            </Border>
                            <TextBlock Grid.Column="1" VerticalAlignment="Center"
                                       FontFamily="{StaticResource FontBarlow}" FontSize="13"
                                       Foreground="{StaticResource TextSecondary}"
                                       Text="cobalt_beacon.bin"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Grid.Column="2" VerticalAlignment="Center"
                                       FontFamily="{StaticResource FontBarlowCondensed}" FontSize="11"
                                       Foreground="{StaticResource TextMuted}"
                                       Margin="16 0 0 0"
                                       Text="YESTERDAY"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource ActivityRow}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Margin="0 0 16 0"
                                    BorderBrush="{StaticResource AccentGoldLight}"
                                    BorderThickness="1" Padding="10 4">
                                <TextBlock FontFamily="{StaticResource FontBarlowCondensed}" FontSize="10"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource AccentGoldLight}" Text="HEURISTIC"/>
                            </Border>
                            <TextBlock Grid.Column="1" VerticalAlignment="Center"
                                       FontFamily="{StaticResource FontBarlow}" FontSize="13"
                                       Foreground="{StaticResource TextSecondary}"
                                       Text="unknown_packer.exe"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Grid.Column="2" VerticalAlignment="Center"
                                       FontFamily="{StaticResource FontBarlowCondensed}" FontSize="11"
                                       Foreground="{StaticResource TextMuted}"
                                       Margin="16 0 0 0"
                                       Text="2 DAYS AGO"/>
                        </Grid>
                    </Border>
                </ItemsControl.Items>
            </ItemsControl>

            <!-- Bottom actions -->
            <StackPanel Orientation="Horizontal"
                        Margin="0 18 0 0"
                        HorizontalAlignment="Right">
                <Button Content="Release Selected"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding ReleaseSelectedCommand}"
                        Margin="0 0 10 0"/>
                <Button Content="Delete Permanently"
                        Style="{StaticResource DangerButton}"
                        Command="{Binding DeletePermanentlyCommand}"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
