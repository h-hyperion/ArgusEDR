<UserControl x:Class="Argus.GUI.Views.DefenderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Argus.GUI.ViewModels">

    <ScrollViewer Style="{StaticResource DarkScrollViewer}">
        <StackPanel>

            <!-- ======================================================== -->
            <!--  Stat cards row                                           -->
            <!-- ======================================================== -->
            <UniformGrid Columns="3" Margin="0 0 0 24">
                <Border Style="{StaticResource StatCard}" Margin="0 0 14 0">
                    <StackPanel>
                        <TextBlock Style="{StaticResource StatLabel}" Text="▸  ETW EVENTS / MIN"/>
                        <TextBlock Style="{StaticResource StatValue}" Text="0" FontSize="30"/>
                        <TextBlock Style="{StaticResource StatFootText}" Text="Awaiting service"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCardB}" Margin="0 0 14 0">
                    <StackPanel>
                        <TextBlock Style="{StaticResource StatLabel}" Text="▸  ACTIVE MONITORS"/>
                        <TextBlock Style="{StaticResource StatValueGold}" Text="{Binding ActiveMonitorText}" FontSize="30"/>
                        <TextBlock Style="{StaticResource StatFootText}" Text="Requires Watchdog"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource StatCardCritical}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource StatLabel}" Text="▸  SIGMA RULES"/>
                        <TextBlock Style="{StaticResource StatValueCritical}" Text="—" FontSize="30"/>
                        <TextBlock Style="{StaticResource StatFootText}" Text="v2.2 feature"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- ======================================================== -->
            <!--  Real-Time Protection toggles                             -->
            <!-- ======================================================== -->
            <TextBlock Text="—  REAL-TIME PROTECTION  —" Style="{StaticResource CinzelSectionTitle}" FontSize="13" Margin="0 0 0 12"/>

            <!-- File System Monitor -->
            <Border Style="{StaticResource ToggleRow}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0 0 16 0">
                        <TextBlock Text="File System Monitor" Style="{StaticResource ToggleRowTitle}"/>
                        <TextBlock Text="Watches for mass encryption and shadow deletion" Style="{StaticResource ToggleRowSub}"/>
                    </StackPanel>
                    <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding FileSystemMonitor}" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- ETW Kernel Events -->
            <Border Style="{StaticResource ToggleRow}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0 0 16 0">
                        <TextBlock Text="ETW Kernel Events" Style="{StaticResource ToggleRowTitle}"/>
                        <TextBlock Text="Process create / network / registry tracing" Style="{StaticResource ToggleRowSub}"/>
                    </StackPanel>
                    <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding EtwKernelEvents}" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- AMSI Script Interception -->
            <Border Style="{StaticResource ToggleRow}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0 0 16 0">
                        <TextBlock Text="AMSI Script Interception" Style="{StaticResource ToggleRowTitle}"/>
                        <TextBlock Text="PowerShell, VBScript, .NET dynamic code" Style="{StaticResource ToggleRowSub}"/>
                    </StackPanel>
                    <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding AmsiInterception}" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- BYOVD Driver Detection -->
            <Border Style="{StaticResource ToggleRow}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0 0 16 0">
                        <TextBlock Text="BYOVD Driver Detection" Style="{StaticResource ToggleRowTitle}"/>
                        <TextBlock Text="LOLDrivers.io feed cross-reference" Style="{StaticResource ToggleRowSub}"/>
                    </StackPanel>
                    <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding ByovdDetection}" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- DNS Sinkhole -->
            <Border Style="{StaticResource ToggleRow}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0 0 16 0">
                        <TextBlock Text="DNS Sinkhole" Style="{StaticResource ToggleRowTitle}"/>
                        <TextBlock Text="OpenPhish + custom blocklists" Style="{StaticResource ToggleRowSub}"/>
                    </StackPanel>
                    <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding DnsSinkhole}" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- EDR-Freeze Detection -->
            <Border Style="{StaticResource ToggleRow}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0 0 16 0">
                        <TextBlock Text="EDR-Freeze Detection" Style="{StaticResource ToggleRowTitle}"/>
                        <TextBlock Text="WER handle monitoring (detect-only)" Style="{StaticResource ToggleRowSub}"/>
                    </StackPanel>
                    <CheckBox Grid.Column="1" Style="{StaticResource ToggleSwitch}" IsChecked="{Binding EdrFreezeDetection}" VerticalAlignment="Center"/>
                </Grid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
