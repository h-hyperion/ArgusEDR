<Application x:Class="Argus.GUI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Argus.GUI"
             xmlns:converters="clr-namespace:Argus.GUI.Converters"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/ArgusTheme.xaml"/>
                <ResourceDictionary Source="Themes/Controls.xaml"/>
                <ResourceDictionary Source="Themes/Cards.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Converters at application scope so they resolve inside ControlTemplates -->
            <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
            <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
